# Render env template (WITH-AI)
# Split into service-specific env blocks in Render dashboard.

############################
# aitoearn-server service
############################
NODE_ENV=production
APP_ENV=production
APP_NAME=aitoearn-server
APP_DOMAIN=api.yourdomain.com
JWT_SECRET=replace-me
INTERNAL_TOKEN=replace-me
MONGODB_URI=mongodb+srv://USER:PASS@cluster.example.mongodb.net/aitoearn?retryWrites=true&w=majority
MONGODB_CHANNEL_URI=
REDIS_URL=rediss://default:YOUR_PASSWORD@YOUR_HOST:6379
REDIS_TLS=true
ASSETS_CONFIG={"provider":"s3","region":"auto","bucketName":"aitoearn","endpoint":"https://<account>.r2.cloudflarestorage.com","publicEndpoint":"https://<public-domain>","cdnEndpoint":"https://<cdn-domain>","accessKeyId":"<access-key>","secretAccessKey":"<secret>","forcePathStyle":true}
AI_URL=http://aitoearn-ai:3010
MAIL_HOST=smtp.resend.com
MAIL_PORT=465
MAIL_SECURE=true
MAIL_FROM="AiToEarn <noreply@yourdomain.com>"
MAIL_USER=resend
MAIL_PASS=
RELAY_SERVER_URL=https://aitoearn.ai/api
RELAY_API_KEY=
RELAY_CALLBACK_URL=https://api.yourdomain.com/api/plat/relay-callback

############################
# aitoearn-ai service
############################
NODE_ENV=production
APP_ENV=production
APP_NAME=aitoearn-ai
JWT_SECRET=replace-me
INTERNAL_TOKEN=replace-me
MONGODB_URI=mongodb+srv://USER:PASS@cluster.example.mongodb.net/aitoearn?retryWrites=true&w=majority
REDIS_URL=rediss://default:YOUR_PASSWORD@YOUR_HOST:6379
REDIS_TLS=true
ASSETS_CONFIG={"provider":"s3","region":"auto","bucketName":"aitoearn","endpoint":"https://<account>.r2.cloudflarestorage.com","publicEndpoint":"https://<public-domain>","cdnEndpoint":"https://<cdn-domain>","accessKeyId":"<access-key>","secretAccessKey":"<secret>","forcePathStyle":true}
SERVER_URL=http://aitoearn-server:3002
OPENAI_API_KEY=
AI_GATEWAY_API_KEY=
AI_GATEWAY_BASE_URL=https://ai-gateway.vercel.sh/v1
OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
GROQ_API_KEY=
GROK_API_KEY=
GEMINI_KEY_PAIRS=[]
GEMINI_LOCATION=us-central1
AICSO_API_KEY=
AICSO_BASE_URL=
AI_PROXY_URL=
POLLINATIONS_IMAGE_BASE_URL=https://gen.pollinations.ai/image
POLLINATIONS_VIDEO_BASE_URL=https://gen.pollinations.ai/video
POLLINATIONS_APP_URL=https://api.piiblog.net
POLLINATIONS_SECRET_KEY=
POLLINATIONS_PUBLISHABLE_KEY=
GOOGLE_FLOW_BROWSER_BASE_URL=
GOOGLE_FLOW_BROWSER_API_KEY=
