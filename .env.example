# =========================================================
# AiToEarn Docker environment template
# Copy this file to .env and update values for your environment.
# =========================================================

# MongoDB / Redis
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=password
MONGODB_HOST=mongodb
MONGODB_PORT=27017
MONGODB_USERNAME=admin
MONGODB_PASSWORD=password
MONGODB_URI=
MONGODB_CHANNEL_URI=
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=password
REDIS_URL=
REDIS_TLS=
DB_NAME=aitoearn
INIT_MONGO_URI=mongodb://admin:password@mongodb:27017

# RustFS
RUSTFS_ACCESS_KEY=rustfsadmin
RUSTFS_SECRET_KEY=rustfsadmin
RUSTFS_BUCKET=aitoearn

# Common app runtime
NODE_ENV=production
APP_ENV=production
AI_APP_NAME=aitoearn-ai
SERVER_APP_NAME=aitoearn-server
NEXT_TELEMETRY_DISABLED=1
JWT_SECRET=change-this-jwt-secret
INTERNAL_TOKEN=change-this-secret-token
AUTO_LOGIN_TOKEN_PATH=/data/init/token.txt
APP_DOMAIN=api.piiblog.net
PUBLISHER_DOMAIN=aitoearn.ai
NEXT_PUBLIC_APP_DOMAIN=api.piiblog.net
NEXT_PUBLIC_APP_URL=https://api.piiblog.net
NEXT_PUBLIC_DOCS_URL=https://docs.aitoearn.ai
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Inter-service URLs
SERVER_URL=http://aitoearn-server:3002
AI_URL=http://aitoearn-ai:3010

# Storage config JSON (must be one-line JSON)
AI_ASSETS_CONFIG={"provider":"s3","region":"auto","bucketName":"aitoearn","endpoint":"https://b2ce9bfa4a1c529524d2aaf6898e8c30.r2.cloudflarestorage.com","publicEndpoint":"https://b2ce9bfa4a1c529524d2aaf6898e8c30.r2.cloudflarestorage.com","cdnEndpoint":"https://b2ce9bfa4a1c529524d2aaf6898e8c30.r2.cloudflarestorage.com","accessKeyId":"replace-me","secretAccessKey":"replace-me","forcePathStyle":true}
SERVER_ASSETS_CONFIG={"provider":"s3","region":"auto","bucketName":"aitoearn","endpoint":"https://b2ce9bfa4a1c529524d2aaf6898e8c30.r2.cloudflarestorage.com","publicEndpoint":"https://b2ce9bfa4a1c529524d2aaf6898e8c30.r2.cloudflarestorage.com","cdnEndpoint":"https://b2ce9bfa4a1c529524d2aaf6898e8c30.r2.cloudflarestorage.com","accessKeyId":"replace-me","secretAccessKey":"replace-me","forcePathStyle":true}

# AI Providers
OPENAI_API_KEY=sk-placeholder
AI_GATEWAY_API_KEY=
AI_GATEWAY_BASE_URL=https://ai-gateway.vercel.sh/v1
OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_API_KEY=sk-placeholder
ANTHROPIC_BASE_URL=https://api.anthropic.com
# Metadata generation providers (used by AI metadata endpoint)
GROQ_API_KEY=
GEMINI_API_KEY=
VOLCENGINE_API_KEY=
VOLCENGINE_ACCESS_KEY_ID=
VOLCENGINE_SECRET_ACCESS_KEY=
VOLCENGINE_VOD_SPACE_NAME=
GROK_API_KEY=
AICSO_API_KEY=
AICSO_BASE_URL=
GEMINI_KEY_PAIRS=[{"apiKey":"replace-me","projectId":"replace-me","keyFile":"/tmp/placeholder-gemini-key.json","bucket":"placeholder-bucket"}]
GEMINI_LOCATION=us-central1
AI_PROXY_URL=

# Pollinations (optional)
POLLINATIONS_IMAGE_BASE_URL=https://gen.pollinations.ai/image
POLLINATIONS_VIDEO_BASE_URL=https://gen.pollinations.ai/video
POLLINATIONS_APP_URL=https://api.piiblog.net
POLLINATIONS_SECRET_KEY=
POLLINATIONS_PUBLISHABLE_KEY=

# Email
MAIL_HOST=smtp.resend.com
MAIL_PORT=465
MAIL_SECURE=true
MAIL_FROM=AiToEarn <noreply@email.piiblog.net>
MAIL_USER=resend
MAIL_PASS=re_aLbepo7w_jFyAchdi2sQxgNmctTVkC8CA

# OAuth providers (optional)
BILIBILI_CLIENT_ID=
BILIBILI_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
KWAI_CLIENT_ID=
KWAI_CLIENT_SECRET=
PINTEREST_CLIENT_ID=
PINTEREST_CLIENT_SECRET=
TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_CONFIG_ID=
THREADS_CLIENT_ID=
THREADS_CLIENT_SECRET=
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
YOUTUBE_CLIENT_ID=-.apps.googleusercontent.com
YOUTUBE_CLIENT_SECRET=--
WXPLAT_APP_ID=
WXPLAT_APP_SECRET=
WXPLAT_ENCODING_AES_KEY=
DOYIN_CLIENT_ID=
DOYIN_CLIENT_SECRET=

# SMS
ALI_SMS_ACCESS_KEY_ID=
ALI_SMS_ACCESS_KEY_SECRET=
ALI_SMS_SIGN_NAME=
ALI_SMS_TEMPLATE_CODE=

# Relay
RELAY_SERVER_URL=https://aitoearn.ai/api
RELAY_API_KEY=
RELAY_CALLBACK_URL=https://api.piiblog.net/api/plat/relay-callback

# Google Flow Playwright worker / remote browser
GOOGLE_FLOW_WORKER_PORT=4310
GOOGLE_FLOW_WORKER_API_KEY=
GOOGLE_FLOW_URL=https://labs.google/fx/tools/flow
GOOGLE_FLOW_USER_DATA_DIR=/data/google-flow-user-data
GOOGLE_FLOW_PROFILES_ROOT_DIR=/data/google-flow-user-data
GOOGLE_FLOW_DEBUG_EXPORT_DIR=/project/debug-snapshots
GOOGLE_FLOW_HEADLESS=true
GOOGLE_FLOW_ACTION_TIMEOUT_MS=120000
GOOGLE_FLOW_TASK_TTL_MS=86400000
GOOGLE_FLOW_STEALTH_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/123.0.0.0 Safari/537.36
GOOGLE_FLOW_STEALTH_LOCALE=en-US
GOOGLE_FLOW_STEALTH_TIMEZONE=America/New_York
GOOGLE_FLOW_STEALTH_PLATFORM=Win32
GOOGLE_FLOW_STEALTH_VENDOR=Google Inc.
GOOGLE_FLOW_STEALTH_ACCEPT_LANGUAGE=en-US,en;q=0.9
GOOGLE_FLOW_STEALTH_SEC_CH_UA="Not(A:Brand";v="99", "Google Chrome";v="123", "Chromium";v="123"
GOOGLE_FLOW_STEALTH_SEC_CH_UA_PLATFORM="Windows"
GOOGLE_FLOW_STEALTH_SEC_CH_UA_MOBILE=?0
GOOGLE_FLOW_STEALTH_DNT=1
GOOGLE_FLOW_STEALTH_PLUGIN_ENABLED=true
GOOGLE_FLOW_BROWSER_CHANNEL=chrome
GOOGLE_FLOW_REMOTE_CDP_URL=http://google-flow-remote-browser:9223
GOOGLE_FLOW_REMOTE_LOGIN_OPEN_URL=http://google-flow-remote-browser:4320/v1/login/open
GOOGLE_FLOW_REMOTE_LOGIN_PUBLIC_URL=/flow-login/vnc.html?autoconnect=1&resize=scale

# Google Flow remote browser runtime
GOOGLE_FLOW_REMOTE_BROWSER_PORT=4320
GOOGLE_FLOW_REMOTE_DISPLAY=:99
GOOGLE_FLOW_REMOTE_NOVNC_PORT=6080
GOOGLE_FLOW_REMOTE_CDP_PORT=9222
GOOGLE_FLOW_REMOTE_CDP_PROXY_PORT=9223
GOOGLE_FLOW_REMOTE_VNC_PORT=5900

# AI -> Google Flow browser service bridge
GOOGLE_FLOW_BROWSER_BASE_URL=http://google-flow-playwright-worker:4310
GOOGLE_FLOW_BROWSER_API_KEY=
GOOGLE_FLOW_BROWSER_TIMEOUT_MS=60000
GOOGLE_FLOW_BROWSER_IMAGE_PATH=/v1/image/generate
GOOGLE_FLOW_BROWSER_VIDEO_PATH=/v1/video/generate
GOOGLE_FLOW_BROWSER_TASK_STATUS_PATH=/v1/tasks/{taskId}
GOOGLE_FLOW_BROWSER_LOGIN_URL_PATH=/v1/auth/login-url
GOOGLE_FLOW_BROWSER_SESSION_STATUS_PATH=/v1/auth/session-status
GOOGLE_FLOW_BROWSER_RELOGIN_PATH=/v1/auth/relogin
GOOGLE_FLOW_BROWSER_LOGIN_OPEN_PATH=/v1/profiles/{profileId}/login/open
GOOGLE_FLOW_BROWSER_LOGIN_CREDENTIALS_PATH=/v1/profiles/{profileId}/login/credentials
PLAYWRIGHT_CREDENTIALS_SECRET=
