# ===== AiToEarn Backend (minimal for Groq metadata flow) =====
# Copy to `.env` (or your container env file) and adjust values.

# Core
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change-me
MONGODB_HOST=mongodb
MONGODB_PORT=27017
MONGODB_USERNAME=root
MONGODB_PASSWORD=change-me
JWT_SECRET=change-me
INTERNAL_TOKEN=change-me
SERVER_URL=http://aitoearn-server:3000

# Assets config (JSON string)
ASSETS_CONFIG={"provider":"s3","bucket":"replace-me","region":"us-east-1","endpoint":"https://s3.amazonaws.com","accessKeyId":"replace-me","secretAccessKey":"replace-me","publicEndpoint":"https://cdn.example.com"}

# AI providers
GROK_API_KEY=xai-xxxxxxxx
OPENAI_API_KEY=sk-xxxxxxxx
OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# Gemini image/AICSO path (optional if unused)
AICSO_API_KEY=
AICSO_BASE_URL=

# IMPORTANT:
# If you want to run Groq-only first, keep Gemini key pairs as an empty array.
# This now disables Gemini features without crashing startup.
GEMINI_KEY_PAIRS=[]
GEMINI_LOCATION=us-central1

# Optional unified proxy
AI_PROXY_URL=
